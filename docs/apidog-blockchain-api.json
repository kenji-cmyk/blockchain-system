    "schemas": {
      "ApiEnvelope": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "nullable": true
          },
          "error": {
            "nullable": true,
            "$ref": "#/components/schemas/ApiError"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "ApiError": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "integer",
            "example": 400
          },
          "error": {
            "type": "string",
            "example": "Bad Request"
          },
          "message": {
            "type": "string",
            "example": "Sender balance is insufficient"
          },
          "path": {
            "type": "string",
            "example": "/api/transactions"
          }
        }
      },
      "AddBlockRequest": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "type": "string",
            "example": "{{minerPublicKey}}"
          }
        }
      },
      "CreateTransactionRequest": {
        "type": "object",
        "required": [
          "sender",
          "receiver",
          "amount",
          "privateKey"
        ],
        "properties": {
          "sender": {
            "type": "string",
            "example": "{{senderPublicKey}}"
          },
          "receiver": {
            "type": "string",
            "example": "{{receiverPublicKey}}"
          },
          "amount": {
            "type": "number",
            "format": "double",
            "example": 1.25
          },
          "fee": {
            "type": "number",
            "format": "double",
            "example": 0.05
          },
          "privateKey": {
            "type": "string",
            "example": "{{senderPrivateKey}}"
          }
        }
      },
      "MineTransactionsRequest": {
        "type": "object",
        "required": [
          "rewardAddress"
        ],
        "properties": {
          "rewardAddress": {
            "type": "string",
            "example": "{{minerPublicKey}}"
          }
        }
      },
      "DifficultyRequest": {
        "type": "object",
        "required": [
          "difficulty"
        ],
        "properties": {
          "difficulty": {
            "type": "integer",
            "minimum": 0,
            "maximum": 6,
            "example": 2
          }
        }
      },
      "TamperBlockRequest": {
        "type": "object",
        "required": [
          "index",
          "data"
        ],
        "properties": {
          "index": {
            "type": "integer",
            "example": 1
          },
          "data": {
            "type": "string",
            "example": "tampered-data"
          }
        }
      },
      "RegisterPeerRequest": {
        "type": "object",
        "required": [
          "peerId"
        ],
        "properties": {
          "peerId": {
            "type": "string",
            "example": "node-b"
          },
          "baseUrl": {
            "type": "string",
            "example": "http://localhost:8081"
          }
        }
      },
      "PeerDiscoveryRequest": {
        "type": "object",
        "required": [
          "peerUrls"
        ],
        "properties": {
          "peerUrls": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "http://localhost:8081",
              "http://localhost:8082"
            ]
          }
        }
      },
      "MinePeerBlockRequest": {
        "type": "object",
        "required": [
          "minerAddress"
        ],
        "properties": {
          "minerAddress": {
            "type": "string",
            "example": "{{minerPublicKey}}"
          }
        }
      },
      "Block": {
        "type": "object"
      },
      "Transaction": {
        "type": "object"
      }
