  "info": {
    "title": "Blockchain System API - Apidog Test Import",
    "version": "0.0.1",
    "description": "Import this OpenAPI JSON into Apidog. Set bearer auth to operator-token for protected local demo endpoints. Use variables such as {{senderPublicKey}}, {{senderPrivateKey}}, {{receiverPublicKey}}, {{minerPublicKey}}, {{peerId}}, {{transactionId}}, and {{blockHash}} while testing."
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local backend"
    },
    {
      "url": "http://localhost:8081",
      "description": "Docker Compose node-b"
    },
    {
      "url": "http://localhost:8082",
      "description": "Docker Compose node-c"
    }
  ],
  "tags": [
    {
      "name": "Blocks",
      "description": "Block, chain, validation, and tamper APIs"
    },
    {
      "name": "Wallets",
      "description": "Wallet generation and balance APIs"
    },
    {
      "name": "Transactions",
      "description": "Transaction creation, mempool, broadcast, and mining APIs"
    },
    {
      "name": "Peers",
      "description": "Peer registration, health, discovery, gossip, and sync APIs"
    },
    {
      "name": "Operations",
      "description": "Health, metrics, docs, and node metadata APIs"
    },
    {
      "name": "V1 Enveloped",
      "description": "Versioned APIs returning success/data/error/metadata envelopes"
    }
  ],
  "x-apidog-import-notes": [
    "Import this file as OpenAPI 3.0 in Apidog.",
    "Create wallets first, then copy public/private keys into Apidog variables.",
    "Use operator-token as the Bearer token unless backend config changed.",
    "Legacy /api endpoints return raw learning payloads. /api/v1 endpoints return envelopes."
